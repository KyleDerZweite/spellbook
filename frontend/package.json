{
	"name": "spellbook-frontend",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test:unit": "vitest run",
		"lint": "prettier --check . && svelte-check --tsconfig ./tsconfig.json",
		"format": "prettier --write .",
