# MeiliSearch
MEILI_MASTER_KEY=change-me-to-a-secure-key

# Postgres
POSTGRES_DB=spellbook
POSTGRES_USER=spellbook
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://spellbook:change-me@localhost:5432/spellbook

# Data Pipeline
AGGRESSIVE_PRELOAD=true
SYNC_INTERVAL=daily
LANGUAGES=en

# Frontend auth and app origin
ZITADEL_ISSUER=https://auth.yourdomain.com
ZITADEL_CLIENT_ID=change-me-to-your-zitadel-client-id-exactly-as-shown-in-zitadel
ZITADEL_MOBILE_CLIENT_ID=
APP_ORIGIN=https://spellbook.yourdomain.com
AUTH_SESSION_SECRET=replace-with-32-byte-base64url-secret

# Frontend (browser-facing)
PUBLIC_MEILISEARCH_URL=https://spellbook-search.yourdomain.com

# Scan pipeline
MINIO_REGION=us-east-1
MINIO_BUCKET=spellbook-scans
MINIO_ACCESS_KEY=change-me-to-a-minio-access-key
MINIO_SECRET_KEY=change-me-to-a-minio-secret-key

# Pangolin / Newt (tunnel agent)
PANGOLIN_ENDPOINT=https://pangolin.example.com
NEWT_ID=change-me
NEWT_SECRET=change-me
