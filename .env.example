# MeiliSearch
MEILI_MASTER_KEY=change-me-to-a-secure-key
MEILISEARCH_SEARCH_KEY=change-me-to-a-read-only-key

# Data Pipeline
AGGRESSIVE_PRELOAD=true
SYNC_INTERVAL=daily
LANGUAGES=en

# Auth (shared between SvelteKit and SpacetimeDB)
AUTH_SIGNING_SECRET=change-me-to-a-secure-secret

# Public URLs (browser-facing, routed through Pangolin)
PUBLIC_MEILISEARCH_URL=https://search.yourdomain.com
PUBLIC_SPACETIMEDB_URL=wss://stdb.yourdomain.com

# Pangolin / Newt (tunnel agent)
PANGOLIN_ENDPOINT=https://pangolin.example.com
NEWT_ID=change-me
NEWT_SECRET=change-me
